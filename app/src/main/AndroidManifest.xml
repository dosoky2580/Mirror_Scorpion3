<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="org.tetocollctionway.mirror">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="Mirror Scorpion"
        android:roundIcon="@android:drawable/sym_def_app_icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.MirrorScorpion">
        
        <activity android:name=".MainActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <activity android:name=".TextTranslatorActivity" />
        <activity android:name=".DocLensActivity" />
        <activity android:name=".DialogTranslatorActivity" />
        <activity android:name=".LensActivity" />
        <activity android:name=".DocsEngineActivity" />
        <activity android:name=".StoriesInspirationActivity" />
        <activity android:name=".HadithViewerActivity" />
        <activity android:name=".GamesActivity" />
        <activity android:name=".SettingsActivity" />

    </application>
</manifest>
