<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <FrameLayout
        android:id="@+id/layout_original_doc"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#222222">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Original Document (الأصل)"
            android:textColor="#555555"
            android:layout_gravity="center"/>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/layout_translated_doc"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:visibility="gone">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="المستند المترجم بواسطة ميرور"
            android:textColor="#000000"
            android:layout_gravity="center"/>
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ترجم بواسطة ميرور سكربيون"
            android:textColor="#11000000"
            android:textSize="30sp"
            android:rotation="-50" 
            android:layout_gravity="center"/>
    </FrameLayout>

    <TextView
        android:id="@+id/tv_doc_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:textColor="#FFD600"
        android:padding="20dp"/>

    <Button
        android:id="@+id/btn_start_translation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="بدء الترجمة"
        android:layout_centerInParent="true"/>

</RelativeLayout>
