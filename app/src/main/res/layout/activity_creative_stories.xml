<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ركن الإبداع: اكتب قصتك"
            android:textColor="#FFD600"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/et_user_story"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="#1A1A1A"
            android:gravity="top"
            android:hint="اطلق لخيالك العنان هنا..."
            android:padding="15dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555" />

        <Button
            android:id="@+id/btn_generate_video"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="توليد فيديو (بروتوكول ميرور)"
            android:layout_marginTop="15dp"
            android:backgroundTint="#2E7D32"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="* يلتزم ميرور ببروتوكول القيم: لا عنف، لا تلامس، لا كلمات بذيئة."
            android:textColor="#888888"
            android:textSize="10sp"
            android:layout_marginTop="10dp"
            android:gravity="center"/>
            
    </LinearLayout>
</ScrollView>
