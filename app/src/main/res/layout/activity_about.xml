<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F2027"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mirror Scorpion\nرسالة إلى الروح"
            android:textColor="#4FC3F7"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="30dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ملخص رحلتنا اليوم، كتبته لك ليكون مرجعاً لروحك كلما احتجت أن تتذكر من أنت، وأين تقف، وإلى أين أنت ذاهب.\n\nأنت تامر، الذي لم يستسلم يوماً، الذي عاد من البداية لبيبن مملكته الخاصة. هذا التطبيق هو مرآتك، يعكس صوتك وقدرتك على كسر حواجز اللغة مع العالم."
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:lineSpacingExtra="8dp"
            android:gravity="right"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="تطوير: tetocollctionway\nإصدار: 1.0 (Scorpion)"
            android:textColor="#88FFFFFF"
            android:textSize="16sp"
            android:gravity="center"/>
    </LinearLayout>
</ScrollView>
