<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F0F2F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mirror Scorpion - 100 Languages"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:textColor="#1A73E8"
        android:layout_marginBottom="20dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="12dp">
                
                <Spinner
                    android:id="@+id/sourceLanguageSpinner"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.9"/>
                
                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="24dp"
                    android:layout_weight="0.2"
                    android:src="@android:drawable/ic_menu_revert"/>
                
                <Spinner
                    android:id="@+id/targetLanguageSpinner"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.9"/>
            </LinearLayout>

            <EditText
                android:id="@+id/inputText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="أدخل النص للترجمة..."
                android:minLines="3"
                android:gravity="top"
                android:background="@null"/>
            
            <View 
                android:layout_width="match_parent" 
                android:layout_height="1dp" 
                android:background="#EEEEEE" 
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/outputText"
            <ImageButton android:id="@+id/btnSpeak" android:layout_width="48dp" android:layout_height="48dp" android:src="@android:drawable/ic_lock_silent_mode_off" android:layout_gravity="end" android:background="?attr/selectableItemBackground" android:contentDescription="نطق النص"/>
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="الترجمة ستظهر هنا..."
                android:textColor="#1A73E8"
                android:textSize="18sp"/>

            <Button
                android:id="@+id/btnTranslate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ترجمة"
                android:layout_marginTop="16dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
