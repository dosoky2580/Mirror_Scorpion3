<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"> <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginBottom="20dp">
            
            <ImageView
                android:id="@+id/scorpionReal"
                android:layout_width="150dp"
                android:layout_height="100dp"
                android:layout_centerHorizontal="true"
                android:src="@android:drawable/ic_menu_compass" 
                android:contentDescription="Scorpion"/>

            <ImageView
                android:id="@+id/scorpionMirror"
                android:layout_width="150dp"
                android:layout_height="100dp"
                android:layout_below="@id/scorpionReal"
                android:layout_centerHorizontal="true"
                android:rotationX="180"
                android:alpha="0.3"
                android:src="@android:drawable/ic_menu_compass"/>
        </RelativeLayout>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="1"
            android:alignmentMode="alignMargins">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                android:layout_margin="8dp"
                app:cardBackgroundColor="#1A1A1A">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView android:text="ترجمة نصية" android:textColor="#FFFFFF" android:textStyle="bold" android:layout_gravity="center"/>
                    
                    <Spinner android:id="@+id/langSelector" android:layout_width="200dp" android:layout_height="wrap_content" android:layout_gravity="center" android:layout_margin="10dp"/>

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="120dp" android:background="#262626" android:padding="8dp">
                        <EditText android:id="@+id/editInput" android:layout_width="match_parent" android:layout_height="match_parent" android:hint="اكتب أو تحدث..." android:textColor="#FFFFFF" android:background="@null" android:gravity="top"/>
                        <ImageButton android:id="@+id/micInput" android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_btn_speak_now" android:layout_alignParentBottom="true" android:layout_alignParentLeft="true" android:background="@null"/>
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="2dp" android:background="#1A73E8" android:layout_marginVertical="10dp"/>

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="120dp" android:background="#262626" android:padding="8dp">
                        <TextView android:id="@+id/textOutput" android:layout_width="match_parent" android:layout_height="match_parent" android:textColor="#1A73E8" android:text="الترجمة تظهر هنا..."/>
                        
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentBottom="true" android:layout_alignParentRight="true">
                            <ImageButton android:id="@+id/btnCopy" android:layout_width="35dp" android:layout_height="35dp" android:src="@android:drawable/ic_menu_edit" android:background="@null"/>
                            <ImageButton android:id="@+id/btnShareVoice" android:layout_width="35dp" android:layout_height="35dp" android:src="@android:drawable/ic_menu_share" android:background="@null" android:layout_marginHorizontal="8dp"/>
                            <ImageButton android:id="@+id/btnSpeakOutput" android:layout_width="35dp" android:layout_height="35dp" android:src="@android:drawable/ic_lock_silent_mode_off" android:background="@null"/>
                        </LinearLayout>
                    </RelativeLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            </GridLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="المطور: TetoCollctionWay"
            android:layout_gravity="center"
            android:textColor="#555555"
            android:layout_marginTop="20dp"/>

    </LinearLayout>
</ScrollView>
