<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F0F2F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mirror Scorpion"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:textColor="#1A73E8"
        android:layout_marginBottom="24dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="العربية" android:textStyle="bold"/>
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_revert" android:layout_marginHorizontal="20dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="التركية" android:textStyle="bold"/>
            </LinearLayout>

            <EditText
                android:id="@+id/inputText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="أدخل النص هنا..."
                android:minLines="3"
                android:gravity="top"
                android:background="@null"/>
            
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_verticalPadding="10dp"/>

            <TextView
                android:id="@+id/outputText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="الترجمة ستظهر هنا..."
                android:textColor="#1A73E8"
                android:textSize="18sp"
                android:layout_marginTop="10dp"/>

            <Button
                android:id="@+id/btnTranslate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ترجمة الآن"
                android:backgroundTint="#1A73E8"
                android:textColor="#FFFFFF"
                android:layout_marginTop="16dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
