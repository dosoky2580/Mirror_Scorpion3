<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_gradient_bg">

    <LinearLayout
        android:id="@+id/headerArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center">

        <RelativeLayout
            android:layout_width="100dp"
            android:layout_height="80dp">
            <ImageView
                android:id="@+id/scorpionTop"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_compass"
                app:tint="#FFFFFF"/>
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_below="@id/scorpionTop"
                android:rotationX="180"
                android:alpha="0.2"
                android:src="@android:drawable/ic_menu_compass"
                app:tint="#FFFFFF"/>
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MIRROR ULTIMATE"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"/>
    </LinearLayout>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/headerArea"
        android:columnCount="2"
        android:padding="10dp"
        android:alignmentMode="alignMargins">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#33FFFFFF">
            <LinearLayout android:gravity="center" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">
                <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_menu_sort_alphabetically" app:tint="#FFFFFF"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الترجمة" android:textColor="#FFFFFF" android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#33FFFFFF">
            <LinearLayout android:gravity="center" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">
                <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_menu_camera" app:tint="#FFFFFF"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="العدسة" android:textColor="#FFFFFF" android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        </GridLayout>

</RelativeLayout>
