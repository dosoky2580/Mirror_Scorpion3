<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/img_scorpion"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@android:drawable/ic_btn_speak_now" 
            android:contentDescription="Scorpion" /> <ImageView
            android:layout_width="150dp"
            android:layout_height="100dp"
            android:scaleY="-1"
            android:alpha="0.3"
            android:src="@android:drawable/ic_btn_speak_now" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mirror Scorpion"
            android:textColor="#FFD700"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:alignmentMode="alignMargins">

            <Button android:id="@+id/btn_text_translator" android:text="ترجمة نصية" android:layout_margin="8dp" android:layout_columnWeight="1" android:backgroundTint="#1A1A1A"/>
            <Button android:id="@+id/btn_dialog_translator" android:text="حوار مترجم" android:layout_margin="8dp" android:layout_columnWeight="1" android:backgroundTint="#1A1A1A"/>
            <Button android:id="@+id/btn_doc_lens" android:text="مستندات وعدسة" android:layout_margin="8dp" android:layout_columnWeight="1" android:backgroundTint="#1A1A1A"/>
            <Button android:id="@+id/btn_stories" android:text="قصص وإلهام" android:layout_margin="8dp" android:layout_columnWeight="1" android:backgroundTint="#1A1A1A"/>
            <Button android:id="@+id/btn_games" android:text="الألعاب 3D" android:layout_margin="8dp" android:layout_columnWeight="1" android:backgroundTint="#1A1A1A"/>
            <Button android:id="@+id/btn_settings" android:text="الاعدادات" android:layout_margin="8dp" android:layout_columnWeight="1" android:backgroundTint="#1A1A1A"/>
        </GridLayout>

    </LinearLayout>
</ScrollView>
